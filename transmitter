#include <esp_now.h>
#include <WiFi.h>
#include <Wire.h>
#include <MPU6050_tockn.h>

MPU6050 mpu6050(Wire);

typedef struct {
  char cmd;
} Data;

Data sendData;

uint8_t receiverMAC[] = {0x70, 0x4B, 0xCA, 0x8E, 0xDD, 0xA4};

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA);

  Wire.begin(21, 22);
  // Increase I2C speed to 400kHz for instant data retrieval
  Wire.setClock(400000); 
  
  mpu6050.begin();
  
  Serial.println("Hold STILL for instant calibration...");
  delay(2000); 
  mpu6050.calcGyroOffsets(true);

  if (esp_now_init() != ESP_OK) return;

  esp_now_peer_info_t peer = {};
  memcpy(peer.peer_addr, receiverMAC, 6);
  peer.channel = 0;  
  peer.encrypt = false;
  esp_now_add_peer(&peer);
}

void loop() {
  
  mpu6050.update();
  
  // Directly using the raw angles for zero delay
  float adjX = mpu6050.getAngleX(); 
  float adjY = mpu6050.getAngleY() + 90.0; 

 
  int threshold = 20; 

  if (adjY > threshold)       sendData.cmd = 'F'; 
  else if (adjY < -threshold) sendData.cmd = 'B'; 
  else if (adjX > threshold)  sendData.cmd = 'R'; 
  else if (adjX < -threshold) sendData.cmd = 'L'; 
  else                        sendData.cmd = 'S'; 

  // Send immediately
  esp_now_send(receiverMAC, (uint8_t*)&sendData, sizeof(sendData));

  // Reduced delay to 30ms for "Real-Time" feel
  delay(30); 
}
